# Ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma4

# Provider selection: ollama (local) or gemini (cloud)
AGENT_PROVIDER=ollama

# Gemini (cloud provider) — API key is environment-only, never stored in config
GEMINI_ENABLED=False
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODELS=gemini-2.5-flash,gemini-2.5-pro

# GNews news articles tool — API key is environment-only, never stored in config
GNEWS_ENABLED=False
GNEWS_API_KEY=
GNEWS_MAX_RESULTS=5
GNEWS_LANGUAGE=en
GNEWS_COUNTRY=us

# Auth (REQUIRED — generate with: python -c "import secrets; print(secrets.token_hex(32))")
AUTH_SECRET_KEY=
AUTH_ENABLED=True

# History backend: local (SQLite) or redis
HISTORY_BACKEND_TYPE=local

# Frontend
VITE_API_URL=http://localhost:5000
